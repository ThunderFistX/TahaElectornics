PORT=5000
MONGODB_URI=mongodb://localhost:27017/projectff
JWT_SECRET=your_jwt_secret
SESSION_SECRET=your_session_secret

# Google login requires a Google OAuth Client ID and Client Secret.
# Google Cloud Console redirect URI must match this exactly:
# http://localhost:5000/auth/google/callback
# Required backend libraries: passport and passport-google-oauth20.
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=http://localhost:5000/auth/google/callback

# Frontend app URL used after Google login succeeds or fails.
FRONTEND_URL=http://localhost:3000
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=your_admin_password
STRIPE_SECRET_KEY=sk_test_your_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret
